# ===================================================================
# ArchCoach configuration
# Copy to .env and fill in at least one LLM provider.
# ===================================================================

# ----- LLM provider (required) -----
# one of: openai | anthropic | deepseek | openrouter | ollama
LLM_PROVIDER=deepseek
# API key for the provider above (leave empty for ollama)
LLM_API_KEY=
# model used for the parallel role reviews (a mid-tier model is fine)
LLM_MODEL=deepseek-chat
# model used for summarizing and artifact generation (can be the same)
LLM_STRONG_MODEL=deepseek-chat
# optional fallback "provider:model" used when the primary call fails,
# e.g. openrouter:qwen/qwen-2.5-72b-instruct (uses LLM_FALLBACK_API_KEY)
LLM_FALLBACK_MODEL=
LLM_FALLBACK_API_KEY=
# only needed when LLM_PROVIDER=ollama; from docker use host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
# optional custom base url for openai-compatible endpoints
LLM_BASE_URL=

# ----- database -----
# local development default (docker compose maps postgres to host port 5433);
# inside docker compose this is overridden to the postgres service.
DATABASE_URL=postgres://archcoach:archcoach@localhost:5433/archcoach

# ----- application -----
# v1 runs in single-user local mode without authentication.
# Do NOT expose this app to the public internet with LOCAL_MODE=true.
LOCAL_MODE=true
REVIEW_RATE_LIMIT_PER_HOUR=10
# concurrency/timeout have smart defaults: cloud providers 4 / 120s,
# ollama 1 / 300s (local inference is serial). Override only if needed.
# LLM_MAX_CONCURRENCY=4
# LLM_TIMEOUT_MS=120000
LOG_LEVEL=info
